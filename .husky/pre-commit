#!/bin/sh
# pre-commit hook — 提交前执行代码质量检查
# 如果 TypeScript 或 ESLint 检查失败，提交将被阻止

echo "🔍 [pre-commit] 正在运行代码质量检查..."

# 检查 TypeScript
echo "📝 [pre-commit] TypeScript 编译检查..."
cd "$(dirname "$0")/.."
NODE_OPTIONS="" npx tsc --noEmit
EXIT_CODE=$?

if [ $EXIT_CODE -ne 0 ]; then
  echo "❌ [pre-commit] TypeScript 检查失败！请修复错误后重新提交。"
  echo "   运行 npx tsc --noEmit 查看详细错误"
  exit $EXIT_CODE
fi
echo "✅ [pre-commit] TypeScript 检查通过"

# 检查 ESLint（仅检查暂存区的变更文件，更快速）
echo "📝 [pre-commit] ESLint 代码检查..."
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx)$' | head -20)
if [ -n "$STAGED_FILES" ]; then
  NODE_OPTIONS="" npx eslint $STAGED_FILES
  EXIT_CODE=$?
  if [ $EXIT_CODE -ne 0 ]; then
    echo "❌ [pre-commit] ESLint 检查失败！请修复后重新提交。"
    exit $EXIT_CODE
  fi
fi
echo "✅ [pre-commit] ESLint 检查通过"

# 检查生产构建（与 CI 对齐，拦截会破坏构建的改动）
echo "📦 [pre-commit] 生产构建检查..."
NODE_OPTIONS="" npx vite build
EXIT_CODE=$?
if [ $EXIT_CODE -ne 0 ]; then
  echo "❌ [pre-commit] 生产构建失败！请修复后重新提交。"
  exit $EXIT_CODE
fi
echo "✅ [pre-commit] 生产构建通过"

echo "🎉 [pre-commit] 全部检查通过，提交继续..."
exit 0
